                     change_time,
                	 changed_field_key,	
                     new_value) as rn
    from  "postgres"."public_pipedrive_staging"."stg_deal_changes" 
),
filtered_deals_wrt_stages as (
select
  deal_id,	
  change_time,	
  changed_field_key,	
  new_value 
from deduped
where rn = 1
    and deduped.changed_field_key = 'stage_id'

),
final_formatted as (
select
  deal_id,	
  change_time,	
  changed_field_key,	
