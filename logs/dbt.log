  create  table "postgres"."public_pipedrive_analytics"."fact_deal_activity__dbt_tmp"
  
  
    as
  
  (
    with unioned as (
    select *
    from "postgres"."public_pipedrive_intermediate"."int_union_deals_activity" da
),
